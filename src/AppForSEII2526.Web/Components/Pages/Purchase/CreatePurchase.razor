@page "/purchases/createpurchase"
@attribute [Authorize]
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient api
@inject PurchaseStateContainer purchaseState
@inject NavigationManager nav
@using Microsoft.AspNetCore.Authorization

<h3>Create Purchase</h3>

@if (purchaseState.Purchase.Items.Count == 0)
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <div class="alert alert-secondary mb-3">
        Please fill in your delivery and payment details:
        <ul class="mb-0">
            <li>Street: Include street name and number (min 3 characters).</li>
            <li>City: Enter your city (min 2 characters).</li>
            <li>Postal Code: Enter a valid postal code (min 3 characters).</li>
            <li>Name and Surname: Your full name (min 3 characters each).</li>
            <li>Payment Method Id: Enter an existing payment method id.</li>
            <li>Rating: Optional, between 0 and 5.</li>
        </ul>
    </div>
    <EditForm Model="purchaseState.Purchase" OnValidSubmit="Confirm">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Street</label>
                <InputText class="form-control" @bind-Value="purchaseState.Purchase.Street" placeholder="Street, Number" />
                <ValidationMessage For="() => purchaseState.Purchase.Street" />
            </div>
            <div class="col-md-3">
                <label class="form-label">City</label>
                <InputText class="form-control" @bind-Value="purchaseState.Purchase.City" placeholder="City" />
                <ValidationMessage For="() => purchaseState.Purchase.City" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Postal Code</label>
                <InputText class="form-control" @bind-Value="purchaseState.Purchase.PostalCode" placeholder="Postal Code" />
                <ValidationMessage For="() => purchaseState.Purchase.PostalCode" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="purchaseState.Purchase.NameCustomer" placeholder="Name" />
                <ValidationMessage For="() => purchaseState.Purchase.NameCustomer" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Surname</label>
                <InputText class="form-control" @bind-Value="purchaseState.Purchase.SurnameCustomer" placeholder="Surname" />
                <ValidationMessage For="() => purchaseState.Purchase.SurnameCustomer" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Payment Method Id</label>
                <InputNumber class="form-control" @bind-Value="purchaseState.Purchase.PaymentMethodId" />
                <ValidationMessage For="() => purchaseState.Purchase.PaymentMethodId" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Rating (0-5)</label>
                <InputNumber class="form-control" @bind-Value="purchaseState.Purchase.Rating" />
                <ValidationMessage For="() => purchaseState.Purchase.Rating" />
            </div>
        </div>
        <button class="btn btn-success mt-3" type="submit">Confirm purchase</button>
    </EditForm>
}

@if (!string.IsNullOrWhiteSpace(errors))
{
    <div class="alert alert-warning mt-3">@errors</div>
}

@if (result != null)
{
    <div class="card mt-3">
        <div class="card-header">Purchase created</div>
        <div class="card-body">
            <div>Id: @result.Id</div>
            <div>Total: @result.TotalPrice</div>
            <div>Date: @result.Date</div>
            <div>Address: @result.Street, @result.City (@result.PostalCode)</div>
            <div>Customer: @result.NameSurname</div>
            <div>Payment: @result.PaymentMethod</div>
        </div>
    </div>
}

@code {
    private string? errors;
    private PurchaseForDetailDTO? result;

    private async Task Confirm()
    {
        errors = null;
        result = null;
        try
        {
            var created = await api.CreatePurchaseAsync(purchaseState.Purchase);
            result = created;
            purchaseState.ClearCart();
        }
        catch (AppForSEII2526.Web.API.ApiException ex)
        {
            errors = ex.Message;
        }
        catch (System.Exception ex)
        {
            errors = ex.Message;
        }
    }
}
